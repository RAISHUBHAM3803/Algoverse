# AlgoVerse Server Environment Variables
# Copy these values into Render's Environment Variables dashboard

# Node Environment
NODE_ENV=production
PORT=5008

# Application URLs
CLIENT_URL=https://your-frontend-project.vercel.app # Replace with your Vercel URL
API_URL=https://your-backend-project.onrender.com/api/v1 # Replace with your Render URL

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/algoverse?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_at_least_32_chars
JWT_REFRESH_EXPIRE=7d

# Upstash Redis (For BullMQ)
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:<port>

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
